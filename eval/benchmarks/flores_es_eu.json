{
  "id": "FloresTranslation_es_eu",
  "description": "FLORES-200 translation Spanish → Basque (devtest split)",
  "dataset": {
    "source": "huggingface",
    "path": "openlanguagedata/flores_plus",
    "config": "eus_Latn",
    "target_config": "spa_Latn",
    "split": "devtest",
    "id_field": "id",
    "source_field": "text",
    "target_field": "text",
    "swap_source_target": true
  },
  "prompt": {
    "type": "translation",
    "template": "Translate the following text from Spanish to Basque.\n\nSpanish: {source}\nBasque:"
  },
  "scoring": {
    "type": "translation",
    "metrics": ["chrf", "bleu"]
  },
  "plugin": "flores",
  "default_limit": 200
}
