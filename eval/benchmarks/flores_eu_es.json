{
  "id": "FloresTranslation_eu_es",
  "description": "FLORES-200 translation Basque → Spanish (devtest split)",
  "dataset": {
    "source": "huggingface",
    "path": "openlanguagedata/flores_plus",
    "config": "eus_Latn",
    "target_config": "spa_Latn",
    "split": "devtest",
    "id_field": "id",
    "source_field": "text",
    "target_field": "text"
  },
  "prompt": {
    "type": "translation",
    "template": "Translate the following text from Basque to Spanish.\n\nBasque: {source}\nSpanish:"
  },
  "scoring": {
    "type": "translation",
    "metrics": ["chrf", "bleu"]
  },
  "plugin": "flores",
  "default_limit": 200
}
